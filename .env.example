# Database credentials
DB_USER=sphinx_user
DB_PASSWORD=change_me
DB_NAME=sphinx_db
DB_HOST=localhost
DB_PORT=5432

# YandexGPT credentials
YANDEX_API_KEY=your_key_here
YANDEX_API_KEY_ID=your_key_id_here
YANDEX_API_MODEL_URI=gpt://your_catalog_id/yandexgpt-lite
YANDEX_CLOUD_CATALOG_ID=your_catalog_id_here

# URLs — задаются один раз, остальные дублируют нужное значение
BACKEND_URL=https://your-backend-url.com
FRONTEND_URL=https://your-frontend-url.com

# Telegram credentials
BOT_TOKEN=your_bot_token_here
WEBAPP_URL=${FRONTEND_URL}

# Frontend build (Vite / prod)
VITE_API_URL=${BACKEND_URL}

# Auth
JWT_SECRET=replace-with-a-long-random-string-in-production

# Grafana
GRAFANA_USER=admin
GRAFANA_PASSWORD=change_me

# Alertmanager — SMTP settings for email alerts
# Значения подставляются в alertmanager.yml.template через docker-entrypoint.sh при старте.
# Для Gmail: Настройки аккаунта → Безопасность → Пароли приложений
ALERT_SMTP_HOST=smtp.gmail.com
ALERT_SMTP_PORT=587
ALERT_SMTP_USER=your_email@gmail.com
ALERT_SMTP_PASSWORD=xxxx xxxx xxxx xxxx
ALERT_FROM_EMAIL=your_email@gmail.com
ALERT_TO_EMAIL=team@example.com
